{
  "name": "tauri-vue-nim-template",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run build:release",
    "clean": "bun scripts/clean.ts",
    "format": "bun run format:web && bun run format:rust && bun run format:nim",
    "format:check": "bun run format:web:check && bun run format:rust:check && bun run format:nim:check",
    "format:web": "prettier --write .",
    "format:web:check": "prettier --check .",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --check",
    "format:nim": "bun scripts/format-nim.ts",
    "format:nim:check": "bun scripts/format-nim.ts --check",
    "build:dev": "tauri build --debug --no-bundle",
    "build:release:binary": "tauri build --no-bundle",
    "build:release": "tauri build",
    "build:web": "vue-tsc -b && vite build",
    "build:sidecar": "bun scripts/build-sidecar.ts",
    "build:sidecar:release": "bun scripts/build-sidecar.ts --release",
    "prepare:dev": "bun run build:sidecar && bun run dev",
    "prepare:build": "bun scripts/prepare-build.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:nim": "bun scripts/test-nim.ts",
    "test:sidecar": "bun scripts/test-sidecar.ts",
    "check": "bun run typecheck && bun run test"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "pinia": "^4.0.2",
    "vue": "^3.5.40",
    "vue-router": "^5.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@tauri-apps/cli": "^2.11.4",
    "@types/bun": "^1.3.14",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.11",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.6",
    "tailwindcss": "^4.3.3",
    "typescript": "~5.8.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  }
}
